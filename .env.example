# Copy this file to .env and fill in values. Never commit .env.
# The anon/publishable key is safe for client use; RLS enforces security.
# NEVER put the service_role / secret key here.

SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-publishable-anon-key>

# OneSignal App ID (public, safe to embed in client)
# REST API key is configured server-side only (Supabase Edge Function secret).
ONESIGNAL_APP_ID=<your-onesignal-app-id>
